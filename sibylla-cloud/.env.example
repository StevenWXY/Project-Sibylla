# Sibylla Cloud Service - Environment Variables
# Copy this file to .env and fill in the values

# ============================================
# Application
# ============================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ============================================
# Database (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://sibylla:sibylla@localhost:5432/sibylla

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# JWT Authentication (TASK006)
# ============================================
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# CORS
# ============================================
# Use comma-separated values for multiple origins
# Example: http://localhost:5173,https://app.sibylla.io
CORS_ORIGIN=*

# ============================================
# Gitea (TASK007)
# ============================================
GITEA_URL=http://localhost:3001
GITEA_ADMIN_TOKEN=your-gitea-admin-token

# Gitea (TASK007)
GITEA_URL=http://localhost:3001
GITEA_ADMIN_TOKEN=your-gitea-admin-token
GITEA_ROOT_URL=http://localhost:3001/
GITEA_ADMIN_USERNAME=sibylla-admin
GITEA_ADMIN_PASSWORD=sibylla-admin-password
GITEA_SECRET_KEY=your-gitea-secret-key
